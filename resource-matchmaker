
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #f4f6f8; font-family: system-ui, -apple-system, sans-serif; color: #1a1a2e; padding: 24px; }

  h1 { font-size: 22px; font-weight: 700; margin-bottom: 2px; }
  .subtitle { font-size: 13px; color: #6b7280; margin-bottom: 20px; }

  /* === NAVIGATION TABS === */
  input[name="nav"] { display: none; }
  .nav-bar { display: flex; gap: 0; margin-bottom: 20px; background: #fff; border-radius: 10px; border: 1px solid #e5e7eb; overflow: hidden; }
  .nav-bar label { flex: 1; text-align: center; padding: 12px 8px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s ease; color: #6b7280; border-right: 1px solid #e5e7eb; }
  .nav-bar label:last-child { border-right: none; }
  .nav-bar label:hover { background: #f0f4ff; color: #2563eb; }
  .tab-page { display: none; }

  #tab-matchmaker:checked ~ .nav-bar label[for="tab-matchmaker"],
  #tab-results:checked ~ .nav-bar label[for="tab-results"],
  #tab-scoring:checked ~ .nav-bar label[for="tab-scoring"],
  #tab-all:checked ~ .nav-bar label[for="tab-all"],
  #tab-intake:checked ~ .nav-bar label[for="tab-intake"],
  #tab-workflow:checked ~ .nav-bar label[for="tab-workflow"] { background: #2563eb; color: #fff; }

  #tab-matchmaker:checked ~ .page-matchmaker,
  #tab-results:checked ~ .page-results,
  #tab-scoring:checked ~ .page-scoring,
  #tab-all:checked ~ .page-all,
  #tab-intake:checked ~ .page-intake,
  #tab-workflow:checked ~ .page-workflow { display: block; }

  /* === PROCESS FILTER CHIPS === */
  input[name="process-filter"] { display: none; }
  .chip-group { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 4px; }
  .chip { display: inline-block; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.15s ease; border: 1px solid #d1d5db; color: #374151; background: #fff; }
  .chip:hover { border-color: #2563eb; color: #2563eb; background: #eff6ff; }
  #proc-all:checked ~ .page-matchmaker .chip-group label[for="proc-all"],
  #proc-iqa:checked ~ .page-matchmaker .chip-group label[for="proc-iqa"],
  #proc-pr:checked ~ .page-matchmaker .chip-group label[for="proc-pr"],
  #proc-bg:checked ~ .page-matchmaker .chip-group label[for="proc-bg"],
  #proc-cc:checked ~ .page-matchmaker .chip-group label[for="proc-cc"],
  #proc-ma:checked ~ .page-matchmaker .chip-group label[for="proc-ma"],
  #proc-cv:checked ~ .page-matchmaker .chip-group label[for="proc-cv"] { background: #2563eb; color: #fff; border-color: #2563eb; }

  /* === CARDS & SECTIONS === */
  .section { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 20px; margin-bottom: 16px; }
  .section-title { font-size: 14px; font-weight: 700; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }

  /* === FORM STYLING === */
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
  .form-group { margin-bottom: 0; }
  .form-label { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; font-weight: 600; margin-bottom: 6px; }
  .form-hint { font-size: 11px; color: #9ca3af; margin-top: 4px; }
  .form-select, .form-input, .form-textarea {
    width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 8px;
    font-size: 13px; font-family: system-ui, sans-serif; background: #fff; color: #1a1a2e;
    transition: border-color 0.15s ease;
  }
  .form-textarea { min-height: 72px; resize: vertical; }
  .form-select:focus, .form-input:focus, .form-textarea:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.1); }
  .form-required { color: #dc2626; }

  /* === TABLE === */
  table { width: 100%; border-collapse: collapse; font-size: 12px; }
  thead th { text-align: left; color: #6b7280; font-weight: 600; padding: 9px 10px; border-bottom: 2px solid #e5e7eb; font-size: 10px; text-transform: uppercase; letter-spacing: 0.04em; }
  tbody td { padding: 9px 10px; border-bottom: 1px solid #f0f0f0; vertical-align: middle; }
  tbody tr:hover td { background: #f0f4ff; }
  .mono { font-family: 'SF Mono', 'Cascadia Code', monospace; font-weight: 600; }

  /* === BADGES === */
  .badge { display: inline-block; padding: 2px 9px; border-radius: 20px; font-size: 10px; font-weight: 700; }
  .b-red { background: #fee2e2; color: #991b1b; }
  .b-yellow { background: #fef3c7; color: #92400e; }
  .b-green { background: #d1fae5; color: #065f46; }
  .b-blue { background: #dbeafe; color: #1e40af; }
  .b-purple { background: #ede9fe; color: #5b21b6; }
  .b-gray { background: #f3f4f6; color: #4b5563; }
  .b-teal { background: #ccfbf1; color: #115e59; }

  /* === MATCH SCORE BAR === */
  .score-bar-bg { width: 100%; height: 20px; background: #f0f0f0; border-radius: 10px; overflow: hidden; position: relative; }
  .score-bar-fill { height: 100%; border-radius: 10px; }
  .score-bar-text { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); font-size: 10px; font-weight: 700; color: #374151; font-family: monospace; }
  .fill-score-high { background: linear-gradient(90deg, #34d399, #059669); }
  .fill-score-mid { background: linear-gradient(90deg, #60a5fa, #2563eb); }
  .fill-score-low { background: linear-gradient(90deg, #fbbf24, #d97706); }

  /* === UTIL MINI BAR === */
  .util-mini-bg { width: 70px; height: 14px; background: #f0f0f0; border-radius: 7px; overflow: hidden; display: inline-block; vertical-align: middle; margin-right: 4px; }
  .util-mini-fill { height: 100%; border-radius: 7px; }

  /* === KPI ROW === */
  .kpi-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 16px; }
  .kpi-row-5 { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 16px; }
  .kpi { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 14px; }
  .kpi-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; font-weight: 600; margin-bottom: 4px; }
  .kpi-val { font-size: 24px; font-weight: 700; font-family: 'SF Mono', monospace; }
  .kpi-sub { font-size: 11px; color: #6b7280; margin-top: 2px; }
  .red { color: #dc2626; } .green { color: #059669; } .yellow { color: #d97706; } .blue { color: #2563eb; } .purple { color: #7c3aed; } .teal { color: #0d9488; }

  /* === MATCH CARD === */
  .match-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 16px; margin-bottom: 12px; display: grid; grid-template-columns: 40px 50px 1fr 200px; gap: 16px; align-items: center; transition: all 0.15s ease; }
  .match-card:hover { border-color: #2563eb; box-shadow: 0 2px 8px rgba(37,99,235,0.08); }
  .match-rank { font-size: 28px; font-weight: 800; font-family: 'SF Mono', monospace; color: #d1d5db; text-align: center; }
  .match-rank.top { color: #059669; }
  .match-name { font-size: 15px; font-weight: 700; margin-bottom: 2px; }
  .match-meta { font-size: 12px; color: #6b7280; line-height: 1.6; }
  .match-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 6px; }

  /* === RESULT HEADER === */
  .result-header { background: linear-gradient(135deg, #eff6ff, #e0f2fe); border: 1px solid #bfdbfe; border-radius: 10px; padding: 16px; margin-bottom: 16px; display: flex; justify-content: space-between; align-items: center; }
  .rh-title { font-size: 14px; font-weight: 700; color: #1e40af; }
  .rh-sub { font-size: 12px; color: #3b82f6; margin-top: 2px; }
  .rh-badge { font-size: 32px; font-weight: 800; font-family: monospace; color: #059669; }

  /* === FORMULA BLOCK === */
  .formula-block { background: #f8f9fb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; font-family: 'SF Mono', monospace; font-size: 13px; line-height: 2; color: #374151; }
  .formula-hl { color: #2563eb; font-weight: 700; }

  /* === WORKFLOW PIPELINE === */
  .pipeline { display: flex; align-items: flex-start; gap: 0; margin: 24px 0; flex-wrap: wrap; justify-content: center; }
  .pipe-step { text-align: center; position: relative; flex: 1; min-width: 120px; }
  .pipe-circle { width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px; font-size: 22px; border: 3px solid; }
  .pipe-circle.submitted { border-color: #6b7280; background: #f9fafb; }
  .pipe-circle.review { border-color: #d97706; background: #fffbeb; }
  .pipe-circle.approved { border-color: #2563eb; background: #eff6ff; }
  .pipe-circle.deployed { border-color: #059669; background: #f0fdf4; }
  .pipe-circle.closed { border-color: #6b7280; background: #f3f4f6; }
  .pipe-circle.rejected { border-color: #dc2626; background: #fef2f2; }
  .pipe-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 2px; }
  .pipe-desc { font-size: 10px; color: #6b7280; line-height: 1.4; max-width: 130px; margin: 0 auto; }
  .pipe-arrow { display: flex; align-items: center; padding-top: 16px; color: #d1d5db; font-size: 20px; font-weight: 700; }
  .pipe-branch { display: flex; flex-direction: column; align-items: center; margin-top: 8px; }

  /* === SLA METER === */
  .sla-meter { display: flex; align-items: center; gap: 8px; }
  .sla-bar-bg { flex: 1; height: 24px; background: #f0f0f0; border-radius: 12px; overflow: hidden; position: relative; }
  .sla-bar-fill { height: 100%; border-radius: 12px; }
  .sla-bar-text { position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); font-size: 11px; font-weight: 700; font-family: monospace; }

  /* === REQUEST CARD === */
  .req-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 16px; margin-bottom: 12px; display: grid; grid-template-columns: 60px 1fr 160px; gap: 14px; align-items: center; transition: all 0.15s ease; }
  .req-card:hover { border-color: #2563eb; box-shadow: 0 2px 8px rgba(37,99,235,0.06); }
  .req-id { font-family: 'SF Mono', monospace; font-size: 13px; font-weight: 700; color: #2563eb; text-align: center; }
  .req-meta { font-size: 12px; color: #374151; line-height: 1.6; }
  .req-title { font-size: 14px; font-weight: 700; margin-bottom: 2px; }
  .req-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 5px; }
  .req-status-col { text-align: right; }

  /* === ROLE CARDS === */
  .role-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .role-card { border-radius: 10px; padding: 14px; border: 1px solid #e5e7eb; background: #fff; }
  .role-icon { font-size: 24px; margin-bottom: 6px; }
  .role-name { font-size: 13px; font-weight: 700; margin-bottom: 4px; }
  .role-perms { font-size: 11px; color: #6b7280; line-height: 1.5; }

  /* === TRIGGER CARDS === */
  .trigger-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .trigger-card { border-radius: 10px; padding: 14px; border: 1px solid #e5e7eb; background: #fff; transition: all 0.15s ease; }
  .trigger-card:hover { border-color: #2563eb; }
  .trigger-icon { font-size: 20px; margin-bottom: 4px; }
  .trigger-name { font-size: 13px; font-weight: 700; margin-bottom: 3px; }
  .trigger-desc { font-size: 11px; color: #6b7280; line-height: 1.5; }
  .trigger-rule { font-size: 10px; font-family: monospace; color: #2563eb; margin-top: 4px; padding: 4px 8px; background: #eff6ff; border-radius: 4px; display: inline-block; }

  /* === ALERT BOXES === */
  .alert { border-radius: 10px; padding: 14px; margin-bottom: 12px; }
  .alert-blue { background: #eff6ff; border: 1px solid #bfdbfe; }
  .alert-green { background: #f0fdf4; border: 1px solid #bbf7d0; }

  /* === DETAILS === */
  details { margin-top: 8px; }
  summary { cursor: pointer; font-size: 12px; color: #2563eb; font-weight: 600; padding: 4px 0; }

  /* === ANIMATIONS === */
  .fade-in { opacity: 1; }
  @media (prefers-reduced-motion: no-preference) {
    .fade-in { animation: fadeIn 0.4s ease-out both; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
  }
</style>
</head>
